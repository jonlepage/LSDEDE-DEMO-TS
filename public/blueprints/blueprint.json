        {
          "uuid": "39a5f6d9-59cb-479f-bd17-28bfda31663a",
          "type": "DIALOG",
          "properties": [],
          "label": "player_suggestion-AI",
          "structureKey": "__blueprints__.simple-dialog-flow.player_suggestion-AI",
          "content": "Restons calmes les amis. Si cette carotte géante est réelle, ce serait le festin du siècle pour tout notre clan. Si c'est un leurre, on aura au moins fait notre gym matinale et pris l'air. Qu'est-ce qu'on risque vraiment à aller voir ?",
          "dialogueText": {
            "en": "",
            "fr": "Restons calmes les amis. Si cette carotte géante est réelle, ce serait le festin du siècle pour tout notre clan. Si c'est un leurre, on aura au moins fait notre gym matinale et pris l'air. Qu'est-ce qu'on risque vraiment à aller voir ?"
          },
          "parentLabels": [
            "__blueprints__"
          ],
          "metadata": {
            "characters": [
              {
                "uuid": "60383860-3694-4f1e-9ae4-c1b5bdc9d842",
